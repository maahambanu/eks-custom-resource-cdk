{
  "app": "python app.py",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/__pycache__/**",
      ".venv/**"
    ]
  },
  "context": {
    "env": "development",
    "region": "eu-west-1",
    "platform": {
      "project_name": "swisscom-platform",
      "ssm_parameter_name": "/platform/account/env",
      "environments": {
        "development": {
          "node_count": 2,
          "log_retention_days": 3
        },
        "staging": {
          "node_count": 2,
          "log_retention_days": 7
        },
        "production": {
          "node_count": 2,
          "log_retention_days": 30
        }
      },
      "vpc": {
        "max_azs": 2,
        "nat_gateways": 1
      },
      "node_group": {
        "min_size": 1,
        "max_size": 2
      },
      "eks": {
        "version": "1.30",
        "instance_type": "t3.small",
        "disk_size": 20
      },
      "lambda": {
        "handler": "helm_config.handler.on_event",
        "timeout_seconds": 30,
        "memory_size": 128,
        "log_level": "INFO",
        "tracing_enabled": true
      },
      "ingress_nginx": {
      "repository": "https://kubernetes.github.io/ingress-nginx",
      "chart": "ingress-nginx",
      "version": "4.12.1",
      "release": "ingress-nginx",
      "namespace": "ingress-nginx",
      "service_type": "ClusterIP",
      "admission_webhooks_enabled": false,
      "resources": {
          "requests": {
          "cpu": "50m",
          "memory": "64Mi"
        },
      "limits": {
      "cpu": "100m",
      "memory": "128Mi"
        }
      }
  }
    },
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-eks:kubectlLayer": true
  }
}